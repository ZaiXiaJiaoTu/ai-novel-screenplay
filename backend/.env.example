APP_NAME=ai-novel-screenplay
APP_VERSION=0.1.0
ENV=development
HOST=127.0.0.1
PORT=8000
RELOAD=true
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/ai_novel_screenplay
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_LOCAL_SECRET
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# 生产环境建议：
# ENV=production
# RELOAD=false
# SECRET_KEY 使用高强度随机值，不能使用默认值或示例值。
# DATABASE_URL 使用独立账号和最小权限，不要提交真实密码。
